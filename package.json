{
  "name": "sattrack",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:ngrok": "concurrently -n ngrok,qr,nuxt \"ngrok http 3000\" \"wait-on http://127.0.0.1:4040/api/tunnels && node scripts/ngrok-dev.js\" \"wait-on http://127.0.0.1:4040/api/tunnels && nuxt dev\"",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "deploy": "bash scripts/deploy.sh",
    "release:preview": "bash scripts/preview-release.sh",
    "beta": "bash scripts/deploy.sh beta",
    "production": "bash scripts/deploy.sh release",
    "rollback": "bash scripts/rollback.sh",
    "status": "vercel ls --environment=production 2>/dev/null | head -6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@nuxt/devtools": "latest",
    "@types/crypto-js": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@unocss/nuxt": "^66.6.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "nuxt": "^4.3.1",
    "pngjs": "^7.0.0",
    "qrcode-terminal": "^0.12.0",
    "unocss": "^66.6.2",
    "vconsole": "^3.15.1",
    "vue-eslint-parser": "^9.4.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "crypto-js": "^4.2.0",
    "satellite.js": "4.1.4"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
